COMMERCE_CONTEXT_DIR=.
SKIP_SETUP=false
XDEBUG_MODE=on
PHP_MODE=builtin
POST_INSTALL_CMD=
COMMERCE_WWW_DIR=..
COMPOSER_AUTH=
OPCACHE_ENABLE=1

# tune environment, these suitable for 2.4.8+
PHP_VERSION=8.4
COMPOSER_VERSION=latest-stable
NODE_VERSION=22
MYSQL_IMAGE=mariadb:10.6
VALKEY_IMAGE=valkey/valkey:8
AMPQ_IMAGE=rabbitmq:latest
SEARCH_IMAGE=opensearchproject/opensearch:2
MAILHOG_IMAGE=crapi/mailhog

MYSQL_DUMP_FILE=
